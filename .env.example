# Copy this file to .env for local development.
# Do not commit your real .env file.

WL_DATA_DIR=./data
WL_DB_PATH=./data/web_listening.db
WL_DOWNLOADS_DIR=./data/downloads

# Leave empty to disable OpenAI-backed summaries.
WL_OPENAI_API_KEY=
WL_OPENAI_MODEL=gpt-4o-mini
WL_OPENAI_BASE_URL=https://api.openai.com/v1

WL_USER_AGENT=web-listening-bot/1.0
WL_REQUEST_TIMEOUT=30
